{
  "name": "ses-uygulama",
  "version": "1.0.0",
  "description": "Arkadaşlarla gerçek zamanlı sohbet uygulaması",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "desktop": "electron .",
    "desktop:dev": "electron .",
    "lint": "node scripts/lint.js",
    "test": "node --test",
    "smoke": "node scripts/smoke.js",
    "check": "npm run lint && npm test && npm run smoke",
    "build:win": "electron-builder --win nsis --x64",
    "build:dir": "electron-builder --dir",
    "build:mac": "electron-builder --mac"
  },
  "productName": "SesApp",
  "dependencies": {
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.0"
  },
  "build": {
    "appId": "com.asdakif.sesapp",
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "server/**/*",
      "scripts/**/*",
      "server.js",
      "database.js",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SesApp"
    }
  }
}
